{
  "id": "com.dbw.uxp-ps-imaging-bug",
  "marketplace_id": "[marketplace_id]",
  "name": "UXP PS Imaging Bug",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0",
    "data": {
      "apiVersion": 2
    }
  },
  "manifestVersion": 5,
  "entryPoints": [
    {
      "type": "panel",
      "id": "pnlMain",
      "label": {
        "default": "UXP PS Imaging Bug"
      },
      "minimumSize": {
        "width": 620,
        "height": 830
      },
      "maximumSize": {
        "width": 620,
        "height": 830
      },
      "preferredDockedSize": {
        "width": 620,
        "height": 830
      },
      "preferredFloatingSize": {
        "width": 620,
        "height": 830
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/plugin/panel-dark.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "darkest"
          ],
          "species": [
            "generic"
          ]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/plugin/panel-light.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "light",
            "lightest"
          ],
          "species": [
            "generic"
          ]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/plugin/plugin-dark.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "dark",
        "darkest"
      ]
    },
    {
      "width": 24,
      "height": 24,
      "path": "icons/plugin/plugin-light.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "light",
        "lightest"
      ]
    }
  ]
}
